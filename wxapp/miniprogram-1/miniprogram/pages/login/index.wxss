.login-shell {
  min-height: 100vh;
  padding: 140rpx 48rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.login-glow {
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(50rpx);
}

.glow-top {
  width: 560rpx;
  height: 560rpx;
  top: -180rpx;
  left: -160rpx;
  background: radial-gradient(circle, rgba(132, 169, 140, 0.38) 0%, rgba(132, 169, 140, 0) 70%);
}

.glow-bottom {
  width: 600rpx;
  height: 600rpx;
  right: -200rpx;
  bottom: -220rpx;
  background: radial-gradient(circle, rgba(244, 162, 97, 0.3) 0%, rgba(244, 162, 97, 0) 70%);
}

.login-brand {
  text-align: center;
  margin-bottom: 56rpx;
  position: relative;
}

.logo-outer {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.9), transparent 60%),
    rgba(132, 169, 140, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 0 80rpx rgba(132, 169, 140, 0.35),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.6);
}

.logo-inner {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffffff 0%, #d6e3da 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 16rpx 32rpx rgba(132, 169, 140, 0.3),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.9);
}

.logo-glyph {
  color: #6b9080;
  font-size: 64rpx;
  font-weight: 500;
  line-height: 1;
}

.brand-title {
  display: block;
  color: #2c3e35;
  font-size: 52rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  line-height: 1.2;
}

.brand-subtitle {
  display: block;
  margin: 14rpx auto 0;
  max-width: 460rpx;
  color: #7b8f84;
  font-size: 24rpx;
  font-weight: 300;
  line-height: 1.6;
}

.feature-card {
  padding: 26rpx 28rpx 14rpx;
  position: relative;
}

.feature-row {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 16rpx 0;
}

.feature-row + .feature-row {
  border-top: 2rpx solid rgba(132, 169, 140, 0.12);
}

.feature-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  flex-shrink: 0;
  color: #6b9080;
  box-shadow: 0 12rpx 26rpx rgba(132, 169, 140, 0.16);
}

.feature-dot.tone-sage {
  background: linear-gradient(135deg, #e4efe6 0%, #b9d2c1 100%);
}

.feature-dot.tone-peach {
  background: linear-gradient(135deg, #f8dcc8 0%, #f4a261 100%);
  color: #ffffff;
}

.feature-dot.tone-sea {
  background: linear-gradient(135deg, #d5e7e7 0%, #8fb8b8 100%);
  color: #ffffff;
}

.feature-copy {
  flex: 1;
  min-width: 0;
}

.feature-title {
  display: block;
  color: #2c3e35;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}

.feature-desc {
  display: block;
  margin-top: 4rpx;
  color: #7b8f84;
  font-size: 22rpx;
  line-height: 1.55;
  font-weight: 300;
}

.login-tips {
  margin: 40rpx 0 16rpx;
  text-align: center;
}

.tip-text {
  color: #7b8f84;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.login-button {
  width: 100%;
  min-height: 104rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  background: linear-gradient(135deg, #84a98c 0%, #4f7564 100%);
  color: #ffffff;
  box-shadow:
    0 22rpx 44rpx rgba(132, 169, 140, 0.4),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.28);
}

.login-button::after {
  border: none;
}

.wx-mark {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #07c160;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 14rpx rgba(44, 62, 53, 0.18);
}

.agreement {
  display: block;
  text-align: center;
  margin-top: 26rpx;
  color: #95a79c;
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.profile-card {
  margin-top: 32rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: linear-gradient(135deg, #ffffff 0%, #d6e3da 100%);
  box-shadow:
    0 12rpx 28rpx rgba(132, 169, 140, 0.24),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.85);
}

.profile-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b9080;
  font-size: 42rpx;
  font-weight: 500;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(44, 62, 53, 0.32);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
  z-index: 40;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 40rpx 56rpx;
  background:
    radial-gradient(circle at 12% 10%, rgba(132, 169, 140, 0.18), transparent 56%),
    linear-gradient(180deg, #f7faf7 0%, #eaefea 100%);
  border-radius: 36rpx 36rpx 0 0;
  box-shadow: 0 -18rpx 46rpx rgba(44, 62, 53, 0.18);
  z-index: 41;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(132, 169, 140, 0.32);
  margin: 0 auto 6rpx;
}

.sheet-title {
  color: #2c3e35;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.sheet-subtitle {
  color: #7b8f84;
  font-size: 22rpx;
  font-weight: 300;
  line-height: 1.55;
}

.sheet-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 40rpx rgba(132, 169, 140, 0.14);
}

.avatar-picker {
  width: 112rpx;
  height: 112rpx;
  padding: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(132, 169, 140, 0.2) 0%, rgba(255, 255, 255, 0.8) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 12rpx 28rpx rgba(132, 169, 140, 0.24),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.92);
}

.avatar-picker::after {
  border: none;
}

.avatar-picker-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-picker-placeholder {
  color: #6b9080;
  font-size: 22rpx;
  font-weight: 500;
}

.sheet-input-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.sheet-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(132, 169, 140, 0.2);
  color: #2c3e35;
  font-size: 26rpx;
  box-sizing: border-box;
}

.sheet-confirm {
  margin-top: 8rpx;
}

.sheet-cancel {
  display: block;
  margin-top: 6rpx;
  text-align: center;
  padding: 14rpx 0;
  color: #7b8f84;
  font-size: 24rpx;
}
