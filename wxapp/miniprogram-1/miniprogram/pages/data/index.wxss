.summary-hero {
  padding: 44rpx 26rpx 34rpx;
  text-align: center;
  background:
    radial-gradient(circle at 20% 0%, rgba(132, 169, 140, 0.14), transparent 48%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(132, 169, 140, 0.12) 100%);
}

.summary-hero .section-copy {
  letter-spacing: 2rpx;
}

.minute-line {
  margin: 8rpx 0 6rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 8rpx;
}

.minute-number {
  color: #84a98c;
  font-size: 88rpx;
  font-weight: 300;
  line-height: 1;
  letter-spacing: -2rpx;
}

.minute-unit {
  padding-bottom: 10rpx;
  color: #2c3e35;
  font-size: 26rpx;
  font-weight: 400;
}

.minute-seconds {
  padding-left: 4rpx;
  color: #6b9080;
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 1rpx;
}

.flow-card .flow-head {
  margin-bottom: 4rpx;
}

.artist-empty {
  padding: 16rpx 4rpx 6rpx;
}

.artist-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.artist-rank {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(132, 169, 140, 0.18);
  color: #6b9080;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.artist-row-top .artist-rank {
  background: linear-gradient(135deg, #84a98c 0%, #6b9080 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(132, 169, 140, 0.32);
}

.artist-body {
  flex: 1;
  min-width: 0;
}

.artist-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.artist-head .list-title {
  flex: 1;
  min-width: 0;
}

.artist-head .flow-value {
  flex-shrink: 0;
  color: #6b9080;
}

.artist-row-top .artist-head .flow-value {
  color: #2c3e35;
}

.top-percent {
  display: block;
  margin-bottom: 12rpx;
  color: #f4a261;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.flow-card {
  margin-top: 20rpx;
  padding: 28rpx 26rpx 26rpx;
}

.flow-card .section-title {
  margin-bottom: 6rpx;
  font-size: 28rpx;
}

.flow-item {
  margin-top: 22rpx;
}

.flow-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.flow-head .section-copy {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  color: #2c3e35;
}

.flow-value {
  flex-shrink: 0;
  color: #6b9080;
  font-size: 24rpx;
  font-weight: 600;
}

.stat-row,
.history-preview,
.card-preview {
  margin-top: 16rpx;
}

.card-button {
  margin-top: 22rpx;
}

.card-preview {
  padding: 26rpx;
}

.card-preview-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-preview-frame {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx dashed rgba(132, 169, 140, 0.32);
  display: flex;
  justify-content: center;
}

.card-preview-image {
  width: 100%;
  border-radius: 22rpx;
  box-shadow: 0 18rpx 42rpx rgba(132, 169, 140, 0.22);
}

.card-preview-empty {
  margin-top: 20rpx;
  padding: 34rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 2rpx dashed rgba(132, 169, 140, 0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  text-align: center;
}

.card-preview-orb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffffff 0%, #d4e1da 100%);
  color: #6b9080;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 500;
  box-shadow:
    0 0 42rpx rgba(132, 169, 140, 0.25),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.9);
}

.summary-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 640rpx;
  height: 1200rpx;
  pointer-events: none;
}

.preview-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.preview-actions .primary-button,
.preview-actions .quiet-button {
  padding: 0 14rpx;
  font-size: 24rpx;
}
