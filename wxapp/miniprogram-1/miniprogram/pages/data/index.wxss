.hero {
  padding-top: 12rpx;
}

.summary-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.summary-top,
.history-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-kicker,
.summary-copy,
.summary-week {
  color: rgba(255, 250, 243, 0.74);
  font-size: 22rpx;
}

.summary-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 90rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #ff6a00;
  color: #171411;
  font-size: 20rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.metric-grid,
.insight-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.metric-grid {
  margin: 22rpx 0 18rpx;
}

.metric-cell {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.06);
}

.metric-number {
  display: block;
  font-size: 60rpx;
  font-weight: 900;
}

.metric-label {
  color: rgba(255, 250, 243, 0.72);
  font-size: 22rpx;
}

.dot-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
}

.dot-orange {
  background: #ff6a00;
}

.dot-amber {
  background: #ff8e2b;
}

.dot-peach {
  background: #ffd39c;
}

.dot-green {
  background: #b9f6bc;
}

.dot-blue {
  background: #7fd8ff;
}

.summary-text {
  display: block;
  color: rgba(255, 250, 243, 0.9);
  line-height: 1.7;
  margin-bottom: 10rpx;
}

.insight-grid {
  margin-top: 18rpx;
}

.insight-card,
.history-row,
.card-preview {
  padding: 24rpx;
}

.insight-card {
  min-height: 150rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.insight-title {
  color: #8f8277;
  font-size: 24rpx;
}

.insight-value,
.history-song,
.preview-title {
  font-size: 30rpx;
  font-weight: 800;
}

.history-row {
  margin-bottom: 16rpx;
  gap: 18rpx;
}

.history-mark {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #ffedd8 0%, #ffe0c3 100%);
}

.history-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-action {
  color: #ca6e18;
  font-size: 22rpx;
  font-weight: 700;
}

.ink-button {
  height: 88rpx;
  margin-top: 10rpx;
  border: 0;
  border-radius: 999rpx;
  background: #171411;
  color: #fffaf3;
}

.card-preview {
  margin-top: 18rpx;
}

.preview-url {
  margin-top: 12rpx;
  color: #ca6e18;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}
