<navigation-bar title="听歌数据" back="{{false}}" color="#2d2a20" background="transparent"></navigation-bar>
<scroll-view class="page-shell data-page" scroll-y type="list">
  <text class="eyebrow">个人听歌总结与播放历史</text>
  <view class="title">听歌数据</view>

  <view class="glass-card summary-card">
    <text class="pill rank">{{top}}</text>
    <view class="metric-grid">
      <view>
        <text class="metric-number">{{minutes}}</text>
        <text class="metric-label">分钟</text>
      </view>
      <view>
        <text class="metric-number">{{songs}}</text>
        <text class="metric-label">首歌曲</text>
      </view>
    </view>
    <view class="insight">
      <text>偏好风格</text>
      <text>华语流行 42%</text>
    </view>
    <view class="insight">
      <text>常听时段</text>
      <text>21:00 - 23:00</text>
    </view>
    <button class="primary-button" bindtap="saveSummary">生成个人听歌总结卡片</button>
  </view>

  <view class="section-line">
    <text>播放历史</text>
    <text bindtap="openHistory">全部</text>
  </view>
  <view class="glass-card history-row" wx:for="{{histories}}" wx:key="name">
    <text class="song-name">{{item.name}}</text>
    <text class="muted">{{item.source}}</text>
  </view>
</scroll-view>
