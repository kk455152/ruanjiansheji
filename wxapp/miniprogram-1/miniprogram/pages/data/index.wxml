<navigation-bar title="数据" back="{{false}}" color="#171411" background="transparent"></navigation-bar>
<scroll-view class="page-shell data-page" scroll-y type="list">
  <view class="hero">
    <text class="section-kicker">Listening Report</text>
    <view class="page-title">听歌数据</view>
    <text class="page-subtitle">结合你当前数据库中的播放记录、周报和同步进度，生成贴合设计稿的数据首页。</text>
  </view>

  <view class="dark-card summary-card">
    <view class="summary-top">
      <text class="pill rank-pill">{{topPercent}}</text>
      <text class="summary-week">{{weeklyTitle}}</text>
    </view>

    <view class="metric-grid">
      <view class="metric-cell">
        <text class="metric-number">{{minutes}}</text>
        <text class="metric-label">本周播放分钟</text>
      </view>
      <view class="metric-cell">
        <text class="metric-number">{{songCount}}</text>
        <text class="metric-label">累计歌曲数</text>
      </view>
    </view>

    <text class="summary-text">{{summaryText}}</text>
    <text class="summary-copy">{{compareLastWeek}}</text>

    <button class="primary-button" loading="{{isGenerating}}" bindtap="generateCard">生成听歌总结卡片</button>
  </view>

  <view class="insight-grid">
    <view class="surface-card insight-card">
      <text class="insight-title">偏好风格</text>
      <text class="insight-value">{{favoriteStyle}}</text>
    </view>
    <view class="surface-card insight-card">
      <text class="insight-title">常听时段</text>
      <text class="insight-value">{{activeTime}}</text>
    </view>
    <view class="surface-card insight-card">
      <text class="insight-title">本周最常听歌手</text>
      <text class="insight-value">{{topArtistName}}</text>
      <text class="muted-text">播放 {{topArtistSongCount}} 次</text>
    </view>
    <view class="surface-card insight-card">
      <text class="insight-title">最常进入的歌单</text>
      <text class="insight-value">{{topPlaylistName}}</text>
      <text class="muted-text">进入 {{topPlaylistPlayCount}} 次</text>
    </view>
  </view>

  <view class="surface-card card-preview" wx:if="{{cardImageUrl}}">
    <text class="preview-title">已生成的总结卡片</text>
    <text class="preview-url">{{cardImageUrl}}</text>
  </view>

  <view class="section-heading">
    <text>最近播放</text>
    <text class="right-link" bindtap="openHistory">查看全部</text>
  </view>

  <view
    class="surface-card history-row"
    wx:for="{{historyPreview}}"
    wx:key="historyId"
    data-song-id="{{item.songId}}"
    data-song-name="{{item.songName}}"
    data-artist="{{item.artist}}"
    data-source="{{item.source}}"
    bindtap="replay"
  >
    <view>
      <text class="history-song">{{item.songName}}</text>
      <text class="muted-text">{{item.sourceText}}</text>
    </view>
    <text class="replay-pill">在音箱播放</text>
  </view>
</scroll-view>
