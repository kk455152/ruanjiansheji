<navigation-bar title="听歌总结" back="{{false}}" color="#2C3E35" background="transparent"></navigation-bar>
<scroll-view class="page-shell data-page" scroll-y type="list" enhanced show-scrollbar="{{false}}">
  <view class="page-head">
    <view class="page-head-main">
      <text class="page-title">听歌总结</text>
      <text class="page-subtitle">把最近一周的陪伴、偏好和历史整理成一页。</text>
    </view>
    <view class="page-action" bindtap="openHistory">史</view>
  </view>

  <view class="glass-card glass-card-green summary-hero">
    <text class="section-copy">本周累计陪伴</text>
    <view class="minute-line">
      <text class="minute-number">{{minutes}}</text>
      <text class="minute-unit">分</text>
      <text class="minute-seconds">{{minutesSeconds < 10 ? '0' + minutesSeconds : minutesSeconds}}</text>
      <text class="minute-unit">秒</text>
    </view>
    <text class="top-percent">{{topPercent}} · 共 {{weekPlayCount}} 次播放</text>
    <text class="section-copy">{{liveNote}}</text>
  </view>

  <view class="glass-card flow-card">
    <view class="flow-head">
      <text class="section-title">本周常听艺人</text>
      <text class="flow-value">按播放次数</text>
    </view>

    <view class="artist-empty" wx:if="{{!artistRows.length}}">
      <text class="section-copy">播放几首歌后，这里会根据播放次数自动排名。</text>
    </view>

    <view
      class="artist-row {{item.isTop ? 'artist-row-top' : ''}}"
      wx:for="{{artistRows}}"
      wx:key="artist"
    >
      <view class="artist-rank">{{index + 1}}</view>
      <view class="artist-body">
        <view class="artist-head">
          <text class="list-title">{{item.artist}}</text>
          <text class="flow-value">{{item.playCount}} 次 · {{item.totalMinutes}} 分</text>
        </view>
        <view class="progress-track">
          <view
            class="progress-fill {{item.isTop ? '' : 'progress-fill-orange'}}"
            style="width: {{item.playCount >= artistRows[0].playCount ? 100 : (item.playCount / artistRows[0].playCount) * 100}}%;"
          ></view>
        </view>
      </view>
    </view>
  </view>

  <view class="glass-card list-row stat-row">
    <view class="list-copy">
      <text class="list-title">常听时段</text>
      <text class="list-meta">{{activeTime}} · {{weeklyTitle}}</text>
    </view>
    <view class="circle-mark">月</view>
  </view>

  <view class="glass-card list-row stat-row">
    <view class="list-copy">
      <text class="list-title">{{topArtistName}}</text>
      <text class="list-meta">本周常听艺人 · {{topArtistSongCount}} 次播放</text>
    </view>
    <view class="circle-mark">榜</view>
  </view>

  <view class="section-heading">
    <text class="section-title">最近播放</text>
    <text class="right-link" bindtap="openHistory">全部</text>
  </view>
  <view
    class="glass-card list-row history-preview"
    wx:for="{{historyPreview}}"
    wx:key="historyId"
    data-song-id="{{item.songId}}"
    data-song-name="{{item.songName}}"
    data-artist="{{item.artist}}"
    data-source="{{item.source}}"
    bindtap="replay"
  >
    <view class="circle-mark">♪</view>
    <view class="list-copy">
      <text class="list-title">{{item.songName}}</text>
      <text class="list-meta">{{item.sourceText}}</text>
    </view>
    <text class="right-link">重播</text>
  </view>

  <button class="primary-button card-button" loading="{{isGenerating}}" bindtap="generateCard">生成听歌总结卡片</button>

  <view class="glass-card card-preview">
    <view class="card-preview-head">
      <text class="section-title">分享图片</text>
      <text class="section-copy">{{cardImagePath ? '点预览图片可保存到相册' : '基于本地真实听歌数据实时生成'}}</text>
    </view>

    <view class="card-preview-frame" wx:if="{{cardImagePath}}">
      <image class="card-preview-image" src="{{cardImagePath}}" mode="widthFix" show-menu-by-longpress></image>
    </view>
    <view class="card-preview-empty" wx:else>
      <view class="card-preview-orb">♪</view>
      <text class="section-title">{{minutes}} 分 {{minutesSeconds < 10 ? '0' + minutesSeconds : minutesSeconds}} 秒</text>
      <text class="section-copy">{{weekPlayCount}} 次播放 · {{topArtistName}}</text>
    </view>

    <view class="preview-actions">
      <text class="quiet-button" bindtap="copyCardLink">复制链接</text>
      <text class="primary-button" bindtap="previewGeneratedCard">预览图片</text>
    </view>
  </view>

  <canvas
    type="2d"
    id="summaryCanvas"
    class="summary-canvas"
    disable-scroll
  ></canvas>
</scroll-view>
