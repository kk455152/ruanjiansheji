.feedback-card {
  margin-top: 4rpx;
  padding: 28rpx 26rpx;
  display: flex;
  flex-direction: column;
}

.filter-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter-row .pill,
.filter-row .outline-pill {
  height: 64rpx;
  min-height: 64rpx;
  padding: 0 28rpx;
  line-height: 1;
  text-align: center;
}

.field-label {
  margin-top: 30rpx;
}

.rating-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rating-star {
  font-size: 52rpx;
  line-height: 1;
  color: #d4ddd6;
  transition: color 0.15s ease;
}

.rating-star-active {
  color: #f2b705;
}

.rating-tip {
  margin-left: 8rpx;
  color: #7b8f84;
  font-size: 22rpx;
  font-weight: 300;
}

.feedback-textarea {
  margin-top: 16rpx;
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  color: #2c3e35;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.char-count {
  margin-top: 10rpx;
  align-self: flex-end;
  color: #7b8f84;
  font-size: 20rpx;
  font-weight: 300;
}

.submit-button {
  margin-top: 36rpx;
}
