.hero,
.card-top,
.friend-name-line,
.invite-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-top: 12rpx;
}

.hero-search {
  background: rgba(255, 255, 255, 0.92);
  color: #171411;
  box-shadow: 0 18rpx 34rpx rgba(30, 26, 23, 0.08);
}

.room-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.card-kicker,
.room-song,
.room-meta {
  color: rgba(255, 250, 243, 0.74);
}

.card-kicker {
  font-size: 22rpx;
}

.room-main {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.room-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffcf9d 0%, #ff8c34 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171411;
}

.room-glyph {
  font-size: 46rpx;
  font-weight: 800;
}

.room-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.room-title {
  font-size: 40rpx;
  font-weight: 800;
}

.room-song,
.room-meta {
  font-size: 22rpx;
}

.avatar-row,
.button-row {
  display: flex;
  gap: 16rpx;
}

.avatar-row {
  margin: 24rpx 0;
}

.member-badge,
.friend-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.member-badge {
  background: rgba(255, 255, 255, 0.14);
}

.member-badge-ghost {
  color: rgba(255, 250, 243, 0.56);
}

.half-button {
  flex: 1;
}

.dark-button {
  height: 92rpx;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fffaf3;
}

.friend-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.friend-avatar {
  background: #f1e5d7;
  color: #ca6e18;
}

.friend-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.friend-name {
  font-size: 30rpx;
  font-weight: 800;
}

.join-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #171411;
  color: #fffaf3;
  font-size: 22rpx;
}

.invite-card {
  margin-top: 12rpx;
  padding: 24rpx;
  gap: 20rpx;
}

.invite-icon {
  font-size: 34rpx;
  color: #ff6a00;
}
