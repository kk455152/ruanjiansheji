.hero,
.friend-name-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-top: 12rpx;
}

.icon-chip {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  background: #1e1a17;
  color: #fffaf3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.room-card {
  margin-top: 28rpx;
  padding: 34rpx;
}

.room-kicker {
  color: rgba(255, 250, 243, 0.72);
  font-size: 24rpx;
}

.room-title {
  margin-top: 14rpx;
  font-size: 48rpx;
  font-weight: 800;
}

.room-copy {
  margin-top: 10rpx;
  color: rgba(255, 250, 243, 0.78);
  font-size: 24rpx;
}

.avatar-row,
.button-row {
  display: flex;
  gap: 16rpx;
}

.avatar-row {
  margin: 28rpx 0 26rpx;
}

.member-badge,
.friend-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.member-badge {
  background: rgba(255, 255, 255, 0.14);
}

.half-button {
  flex: 1;
}

.friend-row,
.share-preview {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.friend-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.friend-avatar {
  background: rgba(242, 139, 52, 0.18);
  color: #ca6e18;
}

.friend-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.friend-name {
  font-size: 30rpx;
  font-weight: 800;
}

.join-pill {
  height: 54rpx;
  font-size: 22rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 800;
}

.preview-url {
  margin-top: 14rpx;
  color: #ca6e18;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}
