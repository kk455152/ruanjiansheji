.headline {
  margin: 18rpx 0 28rpx;
}

.eyebrow,
.muted {
  color: #6f8aa8;
  font-size: 24rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 52rpx;
  font-weight: 800;
}

.room-card {
  padding: 34rpx;
}

.room-status {
  color: #38678f;
  font-weight: 700;
}

.room-name {
  margin: 14rpx 0 8rpx;
  font-size: 48rpx;
  font-weight: 800;
}

.avatars {
  display: flex;
  margin: 28rpx 0;
}

.avatar,
.friend-avatar {
  width: 72rpx;
  height: 72rpx;
  margin-right: -10rpx;
  border: 4rpx solid #f7fbff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff77b7, #68bfff);
  color: #ffffff;
  font-weight: 800;
}

.action-row,
.friend-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.half {
  flex: 1;
}

.section-title {
  margin: 38rpx 0 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.friend-row {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.friend-avatar {
  margin-right: 0;
}

.friend-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.friend-name {
  font-weight: 800;
}

.join-pill {
  width: 92rpx;
  height: 52rpx;
}
