<navigation-bar title="好友" back="{{false}}" color="#171411" background="transparent"></navigation-bar>
<scroll-view class="page-shell friends-page" scroll-y type="list" enhanced show-scrollbar="{{false}}">
  <view class="hero hero-split">
    <view>
      <text class="section-kicker">Shared Listening</text>
      <view class="page-title">听歌好友</view>
      <text class="page-subtitle">和朋友共享当前播放，用房间和歌曲卡片把一首歌传到同一个时刻。</text>
    </view>
    <view class="hero-circle hero-search">⌕</view>
  </view>

  <view class="dark-card room-card">
    <view class="card-top">
      <text class="card-kicker">一起听进行中</text>
      <text class="mini-badge">{{roomMemberCount}} 人</text>
    </view>

    <view class="room-main">
      <view class="room-cover">
        <text class="room-glyph">♫</text>
      </view>
      <view class="room-copy">
        <view class="room-title">{{roomName}}</view>
        <text class="room-song">{{roomSongName}}</text>
        <text class="room-meta">房间已创建，当前成员可以同步加入播放节奏</text>
      </view>
    </view>

    <view class="avatar-row">
      <view class="member-badge" wx:for="{{members}}" wx:key="name">{{item.shortName}}</view>
      <view class="member-badge member-badge-ghost" wx:if="{{!members.length}}">M</view>
    </view>

    <view class="button-row">
      <button class="primary-button half-button" loading="{{isCreating}}" bindtap="createRoom">一起听</button>
      <button class="dark-button half-button" loading="{{isSharing}}" bindtap="shareCurrentSong">分享歌曲</button>
    </view>
  </view>

  <view class="section-heading">
    <text>最近一起听的好友</text>
    <text class="right-link" wx:if="{{isLoading}}">刷新中</text>
  </view>

  <view class="surface-card friend-row" wx:for="{{recentFriends}}" wx:key="friendId">
    <view class="friend-avatar">{{item.shortName}}</view>
    <view class="friend-copy">
      <view class="friend-name-line">
        <text class="friend-name">{{item.name}}</text>
        <view class="status-dot {{item.isOnline ? 'status-online' : 'status-offline'}}"></view>
      </view>
      <text class="muted-text">{{item.status}}</text>
    </view>
    <text class="join-pill" data-name="{{item.name}}" bindtap="createRoomWithFriend">{{item.isOnline ? '加入' : '邀请'}}</text>
  </view>

  <view class="soft-card soft-peach invite-card">
    <view>
      <text class="section-card-title">把这首歌发给你想一起听的好友</text>
      <text class="section-card-copy" wx:if="{{sharePreviewUrl}}">{{sharePreviewUrl}}</text>
      <text class="section-card-copy" wx:else>生成分享卡片后，预览地址会显示在这里，方便你继续转发。</text>
    </view>
    <text class="invite-icon">↗</text>
  </view>
</scroll-view>
