.device-summary {
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.device-copy {
  flex: 1;
  min-width: 0;
}

.device-copy .section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.device-copy .section-copy {
  margin-top: 6rpx;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.battery-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 6rpx solid #84a98c;
  color: #2c3e35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.55);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.8);
}

.player-card {
  margin-top: 20rpx;
  padding: 28rpx 26rpx 24rpx;
}

.track-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.cover-tile,
.cover-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  box-shadow: 0 14rpx 30rpx rgba(44, 62, 53, 0.26);
}

.cover-tile {
  background: linear-gradient(135deg, #2c3e35 0%, #435b4d 100%);
  color: rgba(255, 255, 255, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.cover-image {
  background: #2c3e35;
  object-fit: cover;
}

.track-copy {
  flex: 1;
  min-width: 0;
}

.track-copy .section-title {
  font-size: 30rpx;
}

.track-copy .section-copy {
  margin-top: 6rpx;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: nowrap;
  overflow: hidden;
}

.track-meta-pill {
  flex-shrink: 0;
  max-width: 260rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(132, 169, 140, 0.16);
  color: #6b9080;
  font-size: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-meta-dim {
  background: rgba(255, 255, 255, 0.7);
  color: #7b8f84;
}

.player-controls {
  margin: 30rpx 24rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  color: #7b8f84;
  background: rgba(255, 255, 255, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 400;
  box-shadow: 0 8rpx 20rpx rgba(132, 169, 140, 0.14);
}

.play-button {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  color: #ffffff;
  background: linear-gradient(135deg, #2c3e35 0%, #435b4d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 16rpx 34rpx rgba(44, 62, 53, 0.3);
}

.volume-box {
  margin-top: 24rpx;
  padding: 18rpx 22rpx 4rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.volume-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #2c3e35;
  font-size: 22rpx;
  font-weight: 500;
}

.volume-head text:last-child {
  color: #84a98c;
  font-weight: 600;
}

.volume-slider {
  margin: 6rpx 0 0;
}

.grid-menu {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.grid-item {
  min-height: 164rpx;
  padding: 22rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 20rpx 50rpx rgba(132, 169, 140, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #2c3e35;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(132, 169, 140, 0.18) 0%, rgba(132, 169, 140, 0.08) 100%);
  color: #6b9080;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.search-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.search-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.search-head > view {
  flex: 1;
  min-width: 0;
}

.search-bar {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  color: #2c3e35;
  font-size: 24rpx;
  box-sizing: border-box;
}

.search-button {
  flex-shrink: 0;
  min-width: 140rpx;
  height: 84rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #84a98c 0%, #6b9080 100%);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 84rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(132, 169, 140, 0.28);
}

.selected-song {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(132, 169, 140, 0.14);
  border: 2rpx solid rgba(132, 169, 140, 0.18);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.action-grid .primary-button,
.action-grid .quiet-button {
  min-height: 78rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}

.song-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.song-row {
  box-shadow: 0 10rpx 28rpx rgba(132, 169, 140, 0.08);
}

.song-row-active {
  border-color: rgba(132, 169, 140, 0.92);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 36rpx rgba(132, 169, 140, 0.2);
}

.feedback-entry {
  margin-top: 22rpx;
}

.feedback-entry .circle-mark {
  background: linear-gradient(135deg, rgba(244, 162, 97, 0.22) 0%, rgba(244, 162, 97, 0.1) 100%);
  color: #d98b4a;
}
