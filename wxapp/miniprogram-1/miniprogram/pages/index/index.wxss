.hero,
.card-top,
.service-line,
.line-between,
.search-header,
.switch-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-top: 12rpx;
}

.now-card,
.control-card,
.search-card {
  margin-top: 24rpx;
}

.now-card {
  padding: 28rpx;
}

.card-kicker,
.player-kicker,
.muted-light {
  color: rgba(255, 250, 243, 0.72);
  font-size: 22rpx;
}

.media-row {
  margin-top: 18rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.cover-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffc08a 0%, #ff7b1a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171411;
}

.cover-glyph {
  font-size: 46rpx;
  font-weight: 800;
}

.media-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.song-title {
  font-size: 42rpx;
  line-height: 1.14;
  font-weight: 800;
}

.artist-line {
  color: rgba(255, 250, 243, 0.88);
  font-size: 24rpx;
}

.control-card {
  padding: 22rpx 24rpx 26rpx;
}

.control-strip {
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx 180rpx;
  gap: 16rpx;
  align-items: center;
}

.icon-button,
.play-core,
.queue-core {
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.icon-button {
  height: 88rpx;
  background: #f1ebe4;
  color: #2f2720;
  font-size: 28rpx;
  font-weight: 700;
}

.play-core {
  height: 88rpx;
  background: #ff6a00;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 34rpx rgba(255, 106, 0, 0.24);
}

.queue-core {
  height: 88rpx;
  background: #171411;
  color: #fffaf3;
  font-size: 24rpx;
}

.switch-actions {
  margin-top: 18rpx;
}

.switch-link,
.switch-hint {
  font-size: 22rpx;
}

.switch-link {
  color: #ca6e18;
  font-weight: 700;
}

.switch-hint {
  color: #8f8277;
}

.volume-strip {
  margin-top: 22rpx;
}

.volume-strip slider {
  margin-top: 10rpx;
}

.feature-grid,
.service-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.feature-grid {
  margin-top: 24rpx;
}

.feature-card,
.service-card {
  padding: 22rpx 24rpx;
}

.feature-card {
  min-height: 170rpx;
  display: flex;
  flex-direction: column;
}

.feature-icon {
  display: inline-flex;
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.52);
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  color: #ca6e18;
}

.search-card {
  padding: 26rpx;
}

.search-kicker {
  color: #9f9182;
  font-size: 22rpx;
}

.search-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.search-bar {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f7f0e7;
  box-sizing: border-box;
}

.search-button {
  width: 176rpx;
}

.search-results {
  margin-top: 8rpx;
}

.result-card {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: #fff8f0;
}

.result-card-active {
  box-shadow: inset 0 0 0 2rpx rgba(242, 139, 52, 0.3);
}

.result-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #ece2d6;
}

.result-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.result-name,
.service-name {
  font-size: 30rpx;
  font-weight: 800;
}

.result-tag,
.service-badge {
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 22rpx;
}

.result-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(242, 139, 52, 0.12);
  color: #ca6e18;
  font-weight: 700;
}

.result-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.result-button {
  flex: 1;
}

.service-grid {
  margin-bottom: 12rpx;
}

.service-card {
  min-height: 150rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.service-link {
  margin-top: auto;
  color: #ca6e18;
  font-size: 22rpx;
  font-weight: 700;
}
