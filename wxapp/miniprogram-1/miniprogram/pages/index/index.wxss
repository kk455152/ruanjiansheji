.hero,
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-top: 12rpx;
}

.section-kicker-home {
  color: #ff6a00;
}

.now-card,
.control-card {
  margin-top: 24rpx;
}

.now-card {
  padding: 26rpx;
}

.card-kicker,
.player-kicker,
.muted-light {
  color: rgba(255, 250, 243, 0.72);
  font-size: 22rpx;
}

.media-row {
  margin-top: 18rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.cover-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffc08a 0%, #ff7b1a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171411;
}

.cover-glyph {
  font-size: 46rpx;
  font-weight: 800;
}

.media-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.song-title {
  font-size: 42rpx;
  line-height: 1.14;
  font-weight: 800;
}

.artist-line {
  color: rgba(255, 250, 243, 0.88);
  font-size: 24rpx;
}

.control-card {
  padding: 16rpx 18rpx 10rpx;
}

.control-strip {
  display: grid;
  grid-template-columns: 64rpx 88rpx 64rpx 1fr;
  gap: 16rpx;
  align-items: center;
}

.icon-button,
.play-core {
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.icon-button {
  height: 64rpx;
  background: transparent;
  color: #2f2720;
  font-size: 28rpx;
  font-weight: 700;
}

.play-core {
  width: 88rpx;
  height: 64rpx;
  padding: 0;
  background: #ff6a00;
  color: #171411;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: none;
}

.volume-compact {
  height: 64rpx;
  border-radius: 24rpx;
  background: #f1ebe4;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.volume-icon {
  color: #2f2720;
  font-size: 20rpx;
  font-weight: 700;
}

.volume-meter {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(23, 20, 17, 0.16);
  overflow: hidden;
}

.volume-meter-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #171411;
}

.hidden-slider {
  height: 0;
  opacity: 0;
  margin: 0;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.feature-card {
  min-height: 170rpx;
  padding: 22rpx 24rpx;
  display: flex;
  flex-direction: column;
}

.feature-icon {
  display: inline-flex;
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.52);
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  color: #ca6e18;
}
