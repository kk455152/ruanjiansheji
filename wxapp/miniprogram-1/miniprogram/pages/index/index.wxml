<navigation-bar title="首页" back="{{false}}" color="#171411" background="transparent"></navigation-bar>
<scroll-view class="page-shell home-page" scroll-y type="list" enhanced show-scrollbar="{{false}}">
  <view class="hero hero-split">
    <view>
      <text class="section-kicker section-kicker-home">声音 Mini</text>
      <view class="page-title">智能音箱小程序</view>
    </view>
    <view class="hero-circle" bindtap="openDevice">+</view>
  </view>

  <view class="dark-card now-card">
    <view class="card-top">
      <text class="card-kicker">{{deviceName}} · {{online ? '已连接' : '离线'}}</text>
      <text class="mini-badge">{{battery}}%</text>
    </view>

    <view class="media-row">
      <view class="cover-box">
        <text class="cover-glyph">♪</text>
      </view>
      <view class="media-copy">
        <text class="player-kicker">正在播放</text>
        <view class="song-title">{{currentSong}}</view>
        <text class="artist-line">{{currentArtist}}</text>
        <text class="muted-light">{{currentSource}}</text>
      </view>
    </view>
  </view>

  <view class="surface-card control-card">
    <view class="control-strip">
      <button class="icon-button" bindtap="playPreviousSong">◁</button>
      <button class="play-core" loading="{{isActionLoading}}" bindtap="playFeaturedSong">
        {{previewState === 'playing' || isPlaying ? '暂停' : '播放'}}
      </button>
      <button class="icon-button" bindtap="playNextSong">▷</button>
      <view class="volume-compact">
        <text class="volume-icon">))</text>
        <view class="volume-meter">
          <view class="volume-meter-fill" style="width: {{volume}}%;"></view>
        </view>
      </view>
    </view>

    <slider
      class="hidden-slider"
      value="{{volume}}"
      min="0"
      max="100"
      activeColor="#ff6a00"
      backgroundColor="#e8ddd1"
      bindchange="changeVolume"
    />
  </view>

  <view class="feature-grid">
    <view class="soft-card soft-peach feature-card" bindtap="openFriends">
      <text class="feature-icon">♫</text>
      <text class="section-card-title">听歌好友</text>
      <text class="section-card-copy">一起听 / 分享</text>
    </view>
    <view class="soft-card soft-blue feature-card" bindtap="openData">
      <text class="feature-icon">▥</text>
      <text class="section-card-title">听歌数据</text>
      <text class="section-card-copy">个人总结</text>
    </view>
    <view class="soft-card soft-green feature-card" bindtap="openDevice">
      <text class="feature-icon">▣</text>
      <text class="section-card-title">设备管理</text>
      <text class="section-card-copy">电量 / 连接 / 听感</text>
    </view>
    <view class="soft-card soft-purple feature-card" bindtap="openHistory">
      <text class="feature-icon">↺</text>
      <text class="section-card-title">播放历史</text>
      <text class="section-card-copy">最近 {{historyCount}} 首</text>
    </view>
  </view>
</scroll-view>
