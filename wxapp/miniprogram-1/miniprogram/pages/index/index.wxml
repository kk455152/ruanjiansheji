<navigation-bar title="首页" back="{{false}}" color="#171411" background="transparent"></navigation-bar>
<scroll-view class="page-shell home-page" scroll-y type="list">
  <view class="hero">
    <view>
      <text class="section-kicker">Smart Speaker Mini</text>
      <view class="page-title">首页</view>
      <text class="page-subtitle">{{deviceName}} · {{online ? '在线可用' : '设备离线'}}</text>
    </view>
    <view class="battery-chip pill">{{battery}}%</view>
  </view>

  <view class="dark-card player-card">
    <view class="player-top">
      <view>
        <text class="player-kicker">正在播放</text>
        <view class="song-title">{{currentSong}}</view>
        <text class="artist-line">{{currentArtist}} · {{currentSource}}</text>
      </view>
      <text class="playing-badge">{{isPlaying ? '播放中' : '已暂停'}}</text>
    </view>

    <view class="player-center">
      <view class="record">
        <view class="record-core"></view>
      </view>
      <view class="player-copy">
        <text>{{deviceModel}}</text>
        <text class="muted-light">最近已记录 {{historyCount}} 次播放</text>
        <text class="muted-light">{{syncHint}}</text>
      </view>
    </view>

    <view class="player-actions">
      <button class="queue-button" bindtap="addSongToQueue">加入下一首</button>
      <button class="primary-button play-button" loading="{{isActionLoading}}" bindtap="playFeaturedSong">
        {{isPlaying ? '暂停播放' : '继续播放'}}
      </button>
    </view>

    <view class="volume-block">
      <view class="line-between">
        <text>音量</text>
        <text>{{volume}}%</text>
      </view>
      <slider
        value="{{volume}}"
        min="0"
        max="100"
        activeColor="#f28b34"
        backgroundColor="rgba(255,255,255,0.18)"
        bindchange="changeVolume"
      />
    </view>
  </view>

  <view class="section-heading">
    <text>音乐服务</text>
    <text class="right-link" wx:if="{{isLoading}}">刷新中</text>
  </view>
  <view class="service-grid">
    <view class="surface-card service-card" wx:for="{{services}}" wx:key="service" data-path="{{item.path}}" bindtap="openAuth">
      <view class="service-line">
        <text class="service-name">{{item.serviceName}}</text>
        <text class="pill service-badge">{{item.syncText}}</text>
      </view>
      <text class="muted-text">{{item.accountName}}</text>
      <text class="service-link">查看授权与同步进度</text>
    </view>
  </view>

  <view class="section-heading">
    <text>功能入口</text>
    <text class="muted-text">按设计稿布局联动真实数据</text>
  </view>
  <view class="feature-grid">
    <view class="surface-card feature-card" bindtap="openFriends">
      <text class="feature-title">一起听</text>
      <text class="muted-text">创建房间、分享歌曲卡片</text>
    </view>
    <view class="surface-card feature-card" bindtap="openData">
      <text class="feature-title">听歌总结</text>
      <text class="muted-text">周报、时段偏好、历史重播</text>
    </view>
    <view class="surface-card feature-card" bindtap="openDevice">
      <text class="feature-title">设备状态</text>
      <text class="muted-text">电量、网络、音效和配网进度</text>
    </view>
    <view class="surface-card feature-card" bindtap="openHistory">
      <text class="feature-title">播放历史</text>
      <text class="muted-text">搜索记录并在音箱继续播放</text>
    </view>
  </view>
</scroll-view>
