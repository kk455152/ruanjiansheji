<navigation-bar title="播放历史" color="#171411" background="transparent"></navigation-bar>
<scroll-view class="page-shell history-page" scroll-y type="list" enhanced show-scrollbar="{{false}}">
  <view class="hero">
    <text class="section-kicker">Playback Archive</text>
    <view class="page-title">播放历史</view>
    <text class="page-subtitle">筛选最近播过的歌曲，快速回放，或清理较早的历史记录。</text>
  </view>

  <view class="surface-card search-card">
    <input class="search-input" placeholder="搜索歌曲、歌手或来源" value="{{keyword}}" bindinput="inputKeyword" />
  </view>

  <view class="filter-row">
    <text
      class="{{selectedSource === item.key ? 'pill active-pill' : 'outline-pill filter-pill'}}"
      wx:for="{{sourceOptions}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="selectSource"
    >
      {{item.label}}
    </text>
  </view>

  <view
    class="surface-card history-row"
    wx:for="{{filteredList}}"
    wx:key="historyId"
    data-song-id="{{item.songId}}"
    data-song-name="{{item.songName}}"
    data-artist="{{item.artist}}"
    data-source="{{item.source}}"
    bindtap="replay"
  >
    <view class="history-dot"></view>
    <view class="history-copy">
      <text class="history-song">{{item.songName}}</text>
      <text class="muted-text">{{item.sourceText}}</text>
      <text class="played-at">{{item.playedAtText}}</text>
    </view>
    <text class="replay-action">重播</text>
  </view>

  <button class="ghost-button clear-button" loading="{{isClearing}}" bindtap="clearOldRecords">清理 30 天前历史</button>
</scroll-view>
