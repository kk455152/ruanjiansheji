<navigation-bar title="播放历史" color="#2C3E35" background="transparent"></navigation-bar>
<scroll-view class="page-shell history-page" scroll-y type="list" enhanced show-scrollbar="{{false}}">
  <view class="page-head">
    <view class="page-head-main">
      <text class="page-title">播放历史</text>
      <text class="page-subtitle">筛选最近播放，轻点即可发送到音箱重播。</text>
    </view>
    <view class="page-action" bindtap="clearFilters">清</view>
  </view>

  <view class="glass-card filter-card">
    <input class="search-input" placeholder="搜索歌曲、歌手或来源" value="{{keyword}}" bindinput="inputKeyword" />
    <view class="filter-row">
      <text
        class="{{selectedSource === item.key ? 'pill' : 'outline-pill'}}"
        wx:for="{{sourceOptions}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectSource"
      >
        {{item.label}}
      </text>
    </view>
  </view>

  <view class="section-heading">
    <text class="section-title">{{filteredList.length}} 条记录</text>
    <text class="right-link">{{isLoading ? '刷新中' : '点击重播'}}</text>
  </view>

  <view
    class="glass-card list-row history-row"
    wx:for="{{filteredList}}"
    wx:key="historyId"
    data-song-id="{{item.songId}}"
    data-song-name="{{item.songName}}"
    data-artist="{{item.artist}}"
    data-source="{{item.source}}"
    bindtap="replay"
  >
    <view class="circle-mark">♪</view>
    <view class="list-copy">
      <text class="list-title">{{item.songName}}</text>
      <text class="list-meta">{{item.sourceText}} · {{item.playedAtText}}</text>
    </view>
    <text class="right-link">重播</text>
  </view>

  <view class="glass-card empty-card" wx:if="{{!filteredList.length && !isLoading}}">
    <text class="section-title">没有匹配到记录</text>
    <text class="section-copy">换个关键词，或点击右上角清空筛选。</text>
  </view>

  <button class="ghost-button clear-button" loading="{{isClearing}}" bindtap="clearOldRecords">清理 30 天前历史</button>
</scroll-view>
