.search {
  padding: 24rpx;
}

.search input {
  height: 64rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin: 24rpx 0;
}

.filter-row .pill {
  padding: 12rpx 24rpx;
}

.active {
  background: linear-gradient(135deg, #ff77b7, #68bfff);
  color: #ffffff;
}

.history-row {
  margin-bottom: 18rpx;
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.song-name {
  font-size: 34rpx;
  font-weight: 800;
}

.muted {
  color: #6f8aa8;
  font-size: 24rpx;
}

.action {
  margin-top: 8rpx;
  color: #38678f;
  font-weight: 700;
}
