.hero {
  padding-top: 12rpx;
}

.search-card,
.history-row {
  padding: 24rpx;
}

.search-card {
  margin-top: 24rpx;
}

.search-input {
  height: 72rpx;
}

.filter-row,
.history-row {
  display: flex;
  align-items: center;
}

.filter-row {
  gap: 14rpx;
  margin: 24rpx 0;
}

.filter-pill,
.active-pill {
  height: 52rpx;
  font-size: 22rpx;
}

.history-row {
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.history-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #ffedd8 0%, #ffe0c3 100%);
}

.history-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-song {
  font-size: 30rpx;
  font-weight: 800;
}

.played-at {
  color: #b39f8d;
  font-size: 22rpx;
}

.replay-action {
  color: #ca6e18;
  font-size: 24rpx;
  font-weight: 700;
}

.clear-button {
  margin-top: 12rpx;
}
