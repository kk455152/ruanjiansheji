.filter-card {
  padding: 22rpx;
}

.search-input {
  width: 100%;
  height: 84rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  color: #2c3e35;
  font-size: 24rpx;
  box-sizing: border-box;
}

.filter-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-row {
  margin-bottom: 14rpx;
}

.empty-card {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.clear-button {
  margin-top: 18rpx;
}
