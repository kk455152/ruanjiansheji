.hero,
.device-head,
.settings-line,
.switch-line,
.section-line,
.nearby-card,
.step-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-top: 12rpx;
}

.device-card,
.settings-card,
.nearby-card,
.progress-card {
  margin-top: 26rpx;
  padding: 30rpx;
}

.device-name {
  font-size: 42rpx;
  font-weight: 800;
}

.device-copy,
.meta-label {
  color: rgba(255, 250, 243, 0.7);
  font-size: 24rpx;
}

.device-status {
  height: 50rpx;
  font-size: 22rpx;
}

.battery-panel {
  margin: 28rpx 0 24rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
}

.battery-value {
  font-size: 62rpx;
  font-weight: 900;
}

.device-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.meta-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fffaf3;
}

.settings-line,
.switch-line,
.step-row {
  margin-bottom: 18rpx;
}

.switch-title,
.progress-title,
.nearby-name {
  font-size: 30rpx;
  font-weight: 800;
}

.service-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.service-pill {
  height: 54rpx;
  font-size: 22rpx;
}

.nearby-card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.nearby-signal,
.progress-percent {
  color: #ca6e18;
  font-size: 24rpx;
  font-weight: 700;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  margin: 20rpx 0;
  border-radius: 999rpx;
  background: #eadfd3;
  overflow: hidden;
}

.progress-value {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f28b34, #f4b36e);
}
