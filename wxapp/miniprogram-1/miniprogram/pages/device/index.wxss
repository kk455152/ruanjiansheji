.device-card,
.setting-row,
.account-card,
.progress-card {
  padding: 26rpx;
}

.device-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(132, 169, 140, 0.1) 100%);
}

.device-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.speaker-mark {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f4f7f6 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex-shrink: 0;
  box-shadow: 0 10rpx 24rpx rgba(44, 62, 53, 0.08);
}

.speaker-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #84a98c;
  box-shadow: 0 0 0 4rpx rgba(132, 169, 140, 0.18);
}

.speaker-line {
  width: 40rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #2c3e35;
}

.device-card .list-title {
  font-size: 28rpx;
  font-weight: 600;
}

.device-card .list-meta {
  font-size: 22rpx;
}

.battery-circle {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  border: 5rpx solid #84a98c;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2c3e35;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.6);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.7);
}

.battery-track {
  margin: 22rpx 0 10rpx;
}

.device-card .section-copy {
  display: block;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.setting-row {
  margin-top: 16rpx;
}

.setting-row .list-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.setting-row .list-title {
  font-size: 26rpx;
}

.setting-row .list-meta {
  flex-shrink: 0;
  margin-top: 0;
  color: #6b9080;
  font-size: 22rpx;
  font-weight: 600;
}

.setting-slider {
  margin: 18rpx 8rpx 0;
}

.switch-row {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
}

.switch-row .list-title {
  font-size: 26rpx;
}

.save-button {
  margin-top: 22rpx;
}

.account-card,
.nearby-row,
.progress-card {
  margin-top: 16rpx;
}

.account-card .section-title {
  margin-bottom: 8rpx;
}

.service-pills {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.progress-head,
.step-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.progress-head .section-title {
  font-size: 26rpx;
}

.progress-head .right-link {
  color: #84a98c;
  font-weight: 600;
  font-size: 24rpx;
}

.progress-card .progress-track {
  margin: 18rpx 0;
}

.step-row {
  padding: 12rpx 0;
  border-top: 2rpx dashed rgba(132, 169, 140, 0.22);
}

.step-row .section-copy {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
