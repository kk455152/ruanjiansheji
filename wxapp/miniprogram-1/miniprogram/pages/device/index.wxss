.hero,
.device-head,
.settings-line,
.switch-line,
.section-line,
.nearby-card,
.step-row,
.manage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-top: 12rpx;
}

.device-card,
.management-card,
.settings-card,
.services-card,
.nearby-card,
.progress-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.device-head {
  align-items: center;
  gap: 18rpx;
}

.device-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #fffaf3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.device-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ff6a00;
}

.device-bar {
  width: 42rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #171411;
}

.device-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.device-name {
  font-size: 38rpx;
  font-weight: 800;
}

.device-subtitle,
.device-status-line,
.device-caption {
  color: rgba(255, 250, 243, 0.74);
  font-size: 22rpx;
}

.battery-track {
  width: 100%;
  height: 12rpx;
  margin: 24rpx 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.battery-value {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #7ad56c, #c8f4a8);
}

.management-card {
  padding-top: 10rpx;
  padding-bottom: 10rpx;
}

.manage-row {
  padding: 18rpx 0;
}

.manage-row + .manage-row {
  border-top: 2rpx solid rgba(21, 17, 13, 0.05);
}

.manage-title,
.switch-title,
.progress-title,
.nearby-name {
  font-size: 30rpx;
  font-weight: 800;
}

.manage-copy {
  display: block;
  margin-top: 8rpx;
  color: #8f8277;
  font-size: 22rpx;
}

.manage-arrow,
.manage-link,
.nearby-signal,
.progress-percent {
  color: #ca6e18;
  font-size: 24rpx;
  font-weight: 700;
}

.settings-line,
.switch-line,
.step-row {
  margin-bottom: 18rpx;
}

.service-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.service-pill {
  height: 54rpx;
  font-size: 22rpx;
}

.add-button {
  margin-top: 18rpx;
}

.nearby-card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  margin: 20rpx 0;
  border-radius: 999rpx;
  background: #eadfd3;
  overflow: hidden;
}

.progress-value {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff6a00, #f4b36e);
}
