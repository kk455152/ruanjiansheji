<navigation-bar title="高级设置" back="{{false}}" color="#2C3E35" background="transparent"></navigation-bar>
<scroll-view class="page-shell device-page" scroll-y type="list" enhanced show-scrollbar="{{false}}">
  <view class="page-head">
    <view class="page-head-main">
      <text class="page-title">高级设置</text>
      <text class="page-subtitle">管理音箱状态、听感、提醒和附近设备。</text>
    </view>
    <view class="page-action" bindtap="refreshNearbyDevices">扫</view>
  </view>

  <view class="glass-card device-card">
    <view class="device-main">
      <view class="speaker-mark">
        <view class="speaker-dot"></view>
        <view class="speaker-line"></view>
      </view>
      <view class="list-copy">
        <text class="list-title">{{deviceName}}</text>
        <text class="list-meta">{{modelName}} · {{online ? '在线' : '离线'}} · {{currentNetwork}}</text>
      </view>
      <view class="battery-circle">{{batteryLevel}}%</view>
    </view>
    <view class="progress-track battery-track">
      <view class="progress-fill" style="width: {{batteryLevel}}%;"></view>
    </view>
    <text class="section-copy">{{isCharging ? '正在充电中' : '预计可播放 ' + estimatedPlayTime}}</text>
  </view>

  <view class="glass-card setting-row">
    <view class="list-copy">
      <text class="list-title">音量上限</text>
      <text class="list-meta">{{volumeLimit}}%</text>
    </view>
    <slider class="setting-slider" value="{{volumeLimit}}" min="20" max="100" activeColor="#84A98C" backgroundColor="#DCE8E1" bindchange="changeVolumeLimit" />
  </view>

  <view class="glass-card setting-row">
    <view class="list-copy">
      <text class="list-title">低音增强</text>
      <text class="list-meta">{{bassGain}}</text>
    </view>
    <slider class="setting-slider" value="{{bassGain}}" min="0" max="12" activeColor="#84A98C" backgroundColor="#DCE8E1" bindchange="changeBassGain" />
  </view>

  <view class="glass-card list-row switch-row">
    <view class="list-copy">
      <text class="list-title">满电提醒</text>
      <text class="list-meta">低电量阈值 {{lowBatteryThreshold}}%</text>
    </view>
    <switch checked="{{fullChargeNotice}}" color="#84A98C" bindchange="toggleFullChargeNotice" />
  </view>

  <button class="primary-button save-button" loading="{{saving}}" bindtap="saveDeviceSettings">保存设备设置</button>

  <view class="glass-card account-card">
    <text class="section-title">账号同步</text>
    <view class="service-pills">
      <view class="outline-pill" wx:for="{{services}}" wx:key="serviceName">{{item.serviceName}} · {{item.syncText}}</view>
      <view class="outline-pill" wx:if="{{!services.length}}">还没有已绑定的音乐服务</view>
    </view>
  </view>

  <view class="section-heading">
    <text class="section-title">附近设备</text>
    <text class="right-link" bindtap="refreshNearbyDevices">重新扫描</text>
  </view>
  <view
    class="glass-card list-row nearby-row"
    wx:for="{{nearbyDevices}}"
    wx:key="deviceId"
    data-device-id="{{item.deviceId}}"
    data-device-name="{{item.deviceName}}"
    data-model-name="{{item.modelName}}"
    data-signal-strength="{{item.signalStrength}}"
    bindtap="inspectNearbyDevice"
  >
    <view class="circle-mark">声</view>
    <view class="list-copy">
      <text class="list-title">{{item.deviceName}}</text>
      <text class="list-meta">{{item.modelName}}</text>
    </view>
    <text class="right-link">{{item.signalStrength}} dBm</text>
  </view>

  <view class="glass-card progress-card">
    <view class="progress-head">
      <text class="section-title">配置进度</text>
      <text class="right-link">{{bindProgress}}%</text>
    </view>
    <view class="progress-track"><view class="progress-fill" style="width: {{bindProgress}}%;"></view></view>
    <view class="step-row" wx:for="{{bindSteps}}" wx:key="name">
      <text class="section-copy">{{item.name}}</text>
      <text class="right-link">{{item.label}}</text>
    </view>
  </view>
</scroll-view>
