.auth-hero,
.permission-card {
  margin-top: 24rpx;
  padding: 34rpx;
}

.hero-kicker,
.hero-copy,
.task-copy {
  color: rgba(255, 250, 243, 0.72);
  font-size: 24rpx;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 50rpx;
  line-height: 1.12;
  font-weight: 900;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
  line-height: 1.7;
}

.sync-panel {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
}

.sync-line,
.permission-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sync-line {
  margin-bottom: 14rpx;
}

.sync-progress-track {
  width: 100%;
  height: 14rpx;
  margin: 10rpx 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.sync-progress-value {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f28b34, #f6c089);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.permission-row {
  justify-content: flex-start;
  gap: 16rpx;
  margin: 22rpx 0;
}

.permission-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f28b34;
}

button {
  margin-top: 22rpx;
}
