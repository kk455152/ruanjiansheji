.connect-hero,
.auth-hero,
.permission-card,
.status-card {
  padding: 28rpx 26rpx;
}

.connect-hero,
.auth-hero {
  text-align: center;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(132, 169, 140, 0.12) 100%);
}

.speaker-orb,
.service-hero-icon {
  width: 148rpx;
  height: 148rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.85), transparent 55%),
    rgba(132, 169, 140, 0.2);
  color: #84a98c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 500;
  box-shadow:
    0 0 60rpx rgba(132, 169, 140, 0.26),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.5);
}

.connect-hero .section-title,
.auth-hero .section-title {
  font-size: 30rpx;
  white-space: normal;
}

.connect-hero .section-copy,
.auth-hero .section-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.service-option {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.service-option-active {
  border-color: rgba(132, 169, 140, 0.92);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(132, 169, 140, 0.2);
}

.service-logo {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffffff 0%, #f4f7f6 100%);
  border: 4rpx solid #ffffff;
  color: #2c3e35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 8rpx 22rpx rgba(44, 62, 53, 0.08);
}

.service-option .list-title {
  font-size: 26rpx;
}

.service-option .list-meta {
  font-size: 22rpx;
}

.connect-button,
.later-button {
  margin-top: 22rpx;
}

.permission-card,
.status-card {
  margin-top: 16rpx;
}

.permission-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 0;
}

.permission-row .section-copy {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: #2c3e35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.permission-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #84a98c;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(132, 169, 140, 0.18);
}

.status-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.status-line .list-title {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #2c3e35;
  max-width: 60%;
}

.status-card .progress-track {
  margin: 4rpx 0 14rpx;
}

.status-card .section-copy {
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
