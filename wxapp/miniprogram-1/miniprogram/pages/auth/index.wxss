.auth-page {
  padding-top: 12rpx;
}

.connect-top {
  display: flex;
  align-items: center;
}

.connect-brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.brand-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 12rpx;
  background: #171411;
  color: #ff6a00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.brand-text {
  font-size: 24rpx;
  font-weight: 700;
}

.connect-hero,
.auth-hero,
.permission-card,
.status-card,
.connect-service {
  margin-top: 18rpx;
}

.connect-hero,
.auth-hero,
.permission-card,
.status-card {
  padding: 30rpx;
}

.connect-device {
  height: 240rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.connect-speaker {
  width: 148rpx;
  height: 148rpx;
  border-radius: 40rpx;
  background: #fffaf3;
  box-shadow: 0 0 56rpx rgba(255, 129, 28, 0.22);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.connect-speaker-dot {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ff6a00;
}

.connect-speaker-bars {
  width: 46rpx;
  height: 18rpx;
  border-top: 6rpx solid #171411;
  border-bottom: 6rpx solid #171411;
  border-radius: 12rpx;
}

.connect-wave {
  position: absolute;
  top: 38rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #fffaf3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.connect-copy {
  margin-top: 22rpx;
}

.connect-title,
.auth-title {
  font-size: 46rpx;
  font-weight: 800;
}

.connect-desc,
.hero-copy,
.task-copy,
.connect-service-desc,
.connect-foot {
  display: block;
  color: #7f7368;
  font-size: 24rpx;
  line-height: 1.7;
}

.connect-desc,
.hero-copy,
.task-copy,
.connect-foot {
  margin-top: 14rpx;
}

.connect-section-title,
.section-title {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.connect-service {
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.connect-service-active {
  box-shadow: inset 0 0 0 2rpx rgba(255, 106, 0, 0.24);
}

.connect-service-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.service-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.service-dot-blue {
  background: #3aa7ff;
}

.service-dot-red {
  background: #f0143c;
}

.connect-service-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.connect-service-action {
  color: #ff6a00;
  font-size: 22rpx;
}

.connect-button {
  margin-top: 24rpx;
}

.connect-foot {
  text-align: center;
}

.auth-head {
  margin-bottom: 18rpx;
}

.hero-blue {
  background: linear-gradient(180deg, #e6f2fd 0%, #dbeafa 100%);
}

.hero-pink {
  background: linear-gradient(180deg, #f9ecee 0%, #f7e4e7 100%);
}

.hero-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  margin: 0 auto 20rpx;
  background: #1da1f2;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 800;
}

.hero-pink .hero-icon {
  background: #f0143c;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
}

.hero-copy,
.task-copy {
  text-align: center;
}

.permission-row,
.sync-line {
  display: flex;
  align-items: center;
}

.permission-row {
  gap: 16rpx;
  margin-top: 22rpx;
}

.permission-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff6a00;
}

.permission-text {
  flex: 1;
}

.status-card {
  margin-bottom: 22rpx;
}

.sync-line {
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.sync-progress-track {
  width: 100%;
  height: 14rpx;
  margin: 10rpx 0 14rpx;
  border-radius: 999rpx;
  background: #eadfd3;
  overflow: hidden;
}

.sync-progress-value {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff6a00, #f6c089);
}

button {
  margin-top: 18rpx;
}
