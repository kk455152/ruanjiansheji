<navigation-bar title="音乐授权" color="#2C3E35" background="transparent"></navigation-bar>
<view class="page-shell auth-page" wx:if="{{mode === 'connect'}}">
  <view class="page-head">
    <view class="page-head-main">
      <text class="page-title">连接音乐服务</text>
      <text class="page-subtitle">选择要同步到声盒 Mini 的音乐账号。</text>
    </view>
  </view>

  <view class="connect-hero glass-card">
    <view class="speaker-orb">♪</view>
    <text class="section-title">声盒 Mini</text>
    <text class="section-copy">授权后可同步歌单、播放历史和好友一起听。</text>
  </view>

  <view
    class="glass-card service-option {{selectedService === item.key ? 'service-option-active' : ''}}"
    wx:for="{{serviceOptions}}"
    wx:key="key"
    data-service="{{item.key}}"
    bindtap="selectService"
  >
    <view class="service-logo">{{item.key === 'qq' ? 'Q' : '云'}}</view>
    <view class="list-copy">
      <text class="list-title">{{item.title}}</text>
      <text class="list-meta">{{item.description}}</text>
    </view>
    <text class="right-link">{{selectedService === item.key ? '已选' : '选择'}}</text>
  </view>

  <button class="primary-button connect-button" bindtap="openSelectedService">微信授权并继续</button>
</view>

<view class="page-shell auth-page" wx:elif="{{mode === 'service'}}">
  <view class="page-head">
    <view class="page-head-main">
      <text class="page-title">连接 {{serviceName}}</text>
      <text class="page-subtitle">{{slogan}}</text>
    </view>
    <view class="page-action" bindtap="goBack">‹</view>
  </view>

  <view class="glass-card auth-hero">
    <view class="service-hero-icon">{{heroIcon}}</view>
    <text class="section-title">{{service === 'qq' ? '允许声盒 Mini 访问你的 QQ 音乐' : '授权网易云音乐账号'}}</text>
    <text class="section-copy">{{sectionTitle}}</text>
  </view>

  <view class="glass-card permission-card">
    <view class="permission-row" wx:for="{{permissions}}" wx:key="*this">
      <view class="permission-dot"></view>
      <text class="section-copy">{{item}}</text>
    </view>
  </view>

  <view class="glass-card status-card">
    <view class="status-line">
      <text class="section-copy">当前账号</text>
      <text class="list-title">{{accountName}}</text>
    </view>
    <view class="status-line">
      <text class="section-copy">同步状态</text>
      <text class="right-link">{{syncStatusText}}</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
    <text class="section-copy">{{currentTask}}</text>
  </view>

  <button class="primary-button" loading="{{binding}}" bindtap="bindService">{{serviceButtonText}}</button>
  <button class="ghost-button later-button" bindtap="goBack">稍后再说</button>
</view>
