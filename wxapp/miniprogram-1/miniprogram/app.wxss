/**app.wxss**/
page {
  min-height: 100vh;
  color: #1f3555;
  background:
    radial-gradient(circle at 8% 10%, rgba(255, 173, 210, 0.52), transparent 30%),
    radial-gradient(circle at 88% 4%, rgba(125, 202, 255, 0.5), transparent 30%),
    linear-gradient(180deg, #fff2fa 0%, #eef7ff 46%, #f7fbff 100%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
}

.glass-card {
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 24rpx 70rpx rgba(71, 116, 168, 0.16);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffd7ea, #d8efff);
  color: #23476b;
}

.primary-button {
  height: 92rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff77b7, #68bfff);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 18rpx 44rpx rgba(102, 171, 238, 0.34);
}

.ghost-button {
  height: 80rpx;
  border: 2rpx solid rgba(103, 171, 236, 0.28);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #315779;
}
