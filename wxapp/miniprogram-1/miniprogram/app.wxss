/**app.wxss**/
page {
  min-height: 100vh;
  color: #2d2a20;
  background:
    radial-gradient(circle at 10% 8%, rgba(255, 220, 116, 0.38), transparent 28%),
    linear-gradient(180deg, #fff8e5 0%, #f6edd9 48%, #fffaf0 100%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
}

.glass-card {
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.64);
  box-shadow: 0 24rpx 70rpx rgba(87, 70, 34, 0.12);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #efe3a2;
  color: #3a321b;
}

.primary-button {
  height: 92rpx;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f2a1b, #756437);
  color: #fff7dd;
  font-weight: 700;
  box-shadow: 0 18rpx 44rpx rgba(83, 68, 35, 0.24);
}

.ghost-button {
  height: 80rpx;
  border: 2rpx solid rgba(92, 75, 37, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #4c4124;
}
