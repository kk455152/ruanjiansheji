page {
  min-height: 100vh;
  color: #171411;
  background:
    radial-gradient(circle at 0% 0%, rgba(242, 139, 52, 0.18), transparent 28%),
    radial-gradient(circle at 100% 0%, rgba(255, 211, 168, 0.26), transparent 22%),
    linear-gradient(180deg, #f7efe4 0%, #f8f4ee 46%, #fcfaf7 100%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 0 28rpx 140rpx;
  box-sizing: border-box;
}

.surface-card,
.dark-card {
  border-radius: 36rpx;
  box-sizing: border-box;
}

.surface-card {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(27, 22, 18, 0.05);
  box-shadow: 0 24rpx 64rpx rgba(38, 28, 16, 0.08);
}

.dark-card {
  background: linear-gradient(180deg, #1e1a17 0%, #12100e 100%);
  color: #fffaf3;
  box-shadow: 0 28rpx 64rpx rgba(0, 0, 0, 0.2);
}

.pill,
.outline-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
}

.pill {
  background: rgba(242, 139, 52, 0.14);
  color: #ca6e18;
}

.outline-pill {
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.86);
  color: #594e45;
}

.primary-button {
  height: 92rpx;
  border: 0;
  border-radius: 999rpx;
  background: #f28b34;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(242, 139, 52, 0.3);
}

.ghost-button {
  height: 80rpx;
  border: 2rpx solid rgba(21, 17, 13, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #2f2720;
}

.section-kicker {
  color: #9f9182;
  font-size: 24rpx;
}

.page-title {
  margin-top: 10rpx;
  font-size: 54rpx;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #7f7368;
  font-size: 25rpx;
  line-height: 1.6;
}

.section-heading {
  margin: 40rpx 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 800;
}

.muted-text {
  color: #8f8277;
}

.right-link {
  color: #ca6e18;
  font-size: 24rpx;
  font-weight: 700;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-online {
  background: #3fbf7f;
}

.status-syncing {
  background: #f28b34;
}

.status-offline {
  background: #c8b8a8;
}
